;; ---------------------------------------------------------------------------
;; Integration: Shell Init
;; Opt-in reads for shell init/config files under /etc and $HOME.
;; Source: 55-integrations-optional/shell-init.sb
;; #safehouse-test-id:shell-init-integration#
;; ---------------------------------------------------------------------------

;; Enables shell startup file reads for workflows that require shell-managed
;; path/bootstrap behavior. Disabled by default to reduce accidental exposure
;; of secrets stored in shell dotfiles.

(allow file-read*
    ;; Shared shell startup files and PATH defaults.
    (literal "/private/etc/profile")                                  ;; Shell startup file read by login-shell invocations.
    (literal "/private/etc/paths")                                    ;; PATH defaults used by shell command resolution.
    (subpath "/private/etc/paths.d")                                  ;; Additional PATH fragment directory used by macOS shells.

    ;; Bash startup files.
    (literal "/private/etc/bashrc")                                   ;; Bash startup file read by spawned bash sessions.

    ;; Zsh startup files and completion cache.
    (literal "/private/etc/zprofile")                                 ;; Zsh startup file read by login zsh sessions.
    (literal "/private/etc/zshrc")                                    ;; Zsh startup file read by interactive zsh sessions.
    (home-literal "/.zshenv")                                         ;; Zsh environment file read on every zsh invocation (incl. non-interactive).
    (home-literal "/.zprofile")                                       ;; Zsh profile file read by login zsh sessions.
    (home-literal "/.zshrc")                                          ;; Zsh interactive startup file read by interactive zsh sessions.
    (home-literal "/.zcompdump")                                      ;; Zsh completion dump cache used by compinit.
    (home-prefix "/.zcompdump")                                       ;; Versioned variants like .zcompdump-hostname-5.9.
    (literal "/Applications")                                         ;; Ancestor traversal for Homebrew GUI-app completion symlink targets.
    (literal "/System/Volumes/Data/Applications")                     ;; Data-backed /Applications alias used by some bundle resolution flows.
    (regex #"^/Applications/[^/]+\.app/Contents/Resources(/[^/]+)*/(_[^/]+|[^/]+\.(bash|fish|zsh)|[^/]+\.(bash|fish|zsh)-completion)$") ;; App bundles conventionally keep auxiliary assets under Contents/Resources, and Homebrew casks may symlink completion files from anywhere in that tree.
    (regex #"^/System/Volumes/Data/Applications/[^/]+\.app/Contents/Resources(/[^/]+)*/(_[^/]+|[^/]+\.(bash|fish|zsh)|[^/]+\.(bash|fish|zsh)-completion)$")

    ;; Fish startup files and universal variables.
    (literal "/private/etc/fish/config.fish")                         ;; Fish system config read on shell startup.
    (subpath "/private/etc/fish/conf.d")                              ;; Fish system startup snippets sourced from conf.d.
    (home-literal "/.config/fish")                                    ;; Fish config directory traversal needed before reading nested startup files.
    (home-literal "/.config/fish/config.fish")                        ;; Fish user config read on shell startup.
    (home-subpath "/.config/fish/conf.d")                             ;; Fish user startup snippets sourced from conf.d.
    (home-literal "/.config/fish/fish_variables")                     ;; Fish universal variables database read during shell startup.
)
